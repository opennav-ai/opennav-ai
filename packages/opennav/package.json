{
  "name": "@opennav-ai/opennav",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "homepage": "https://OpenNav.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opennav-ai/opennav-ai.git"
  },
  "bugs": {
    "url": "https://github.com/opennav-ai/opennav-ai/issues"
  },
  "type": "module",
  "main": "./dist/opennav/src/index.cjs",
  "module": "./dist/opennav/src/index.js",
  "types": "./dist/opennav/src/index.d.cts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/opennav/src/index.d.cts",
      "import": "./dist/opennav/src/index.js",
      "require": "./dist/opennav/src/index.cjs"
    },
    "./astro": {
      "types": "./dist/opennav/src/astro.d.cts",
      "import": "./dist/opennav/src/astro.js",
      "require": "./dist/opennav/src/astro.cjs"
    },
    "./next": {
      "types": "./dist/opennav/src/next.d.cts",
      "import": "./dist/opennav/src/next.js",
      "require": "./dist/opennav/src/next.cjs"
    },
    "./server": {
      "types": "./dist/opennav/src/server.d.cts",
      "import": "./dist/opennav/src/server.js",
      "require": "./dist/opennav/src/server.cjs"
    }
  },
  "imports": {
    "#opennav-engine": {
      "types": "./dist/engine/src/index.d.cts",
      "import": "./dist/engine/src/index.js",
      "require": "./dist/engine/src/index.cjs"
    }
  },
  "bin": {
    "opennav": "./dist/opennav/src/cli.cjs",
    "opennav-ai": "./dist/opennav/src/cli.cjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "dist"
  ],
  "zshy": {
    "exports": {
      "./package.json": "./package.json",
      ".": "./src/index.ts",
      "./astro": "./src/astro.ts",
      "./next": "./src/next.ts",
      "./server": "./src/server.ts"
    },
    "bin": {
      "opennav": "./src/cli.ts",
      "opennav-ai": "./src/cli.ts"
    }
  },
  "scripts": {
    "build": "zshy --project tsconfig.build.json && sh ../../scripts/copy-opennav-package-files.sh",
    "pack:check": "npm pack --dry-run --cache ../../.npm-cache",
    "test": "vitest run --root ../.. --reporter=default packages/opennav/src",
    "test:package": "npm run build && node ../../scripts/check-opennav-package-exports.mjs"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "js-tiktoken": "^1.0.21",
    "neverthrow": "^8.2.0",
    "parse5": "^8.0.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "zshy": "^0.7.1"
  }
}
