{
  "name": "@opennav-ai/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "zshy": {
    "exports": {
      "./package.json": "./package.json",
      ".": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "zshy --project tsconfig.build.json",
    "pack:check": "npm pack --dry-run --cache ../../.npm-cache",
    "test:package": "npm run build && node ../../scripts/check-engine-package-types.mjs",
    "test": "vitest run --reporter=default"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21",
    "neverthrow": "^8.2.0",
    "parse5": "^8.0.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "zshy": "^0.7.1"
  }
}
