---
import LanguageSelect from "virtual:starlight/components/LanguageSelect";
import Search from "virtual:starlight/components/Search";
import SiteTitle from "virtual:starlight/components/SiteTitle";
import SocialIcons from "virtual:starlight/components/SocialIcons";
import ThemeSelect from "virtual:starlight/components/ThemeSelect";
import config from "virtual:starlight/user-config";

const shouldRenderSearch =
  config.pagefind ||
  config.components.Search !== "@astrojs/starlight/components/Search.astro";

const isDocsHome =
  Astro.url.pathname === "/" || Astro.url.pathname === "/index.html";
const isGettingStartedPage = Astro.url.pathname === "/getting-started/";
const isSdkPage = Astro.url.pathname === "/sdk/";
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <div class="sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
    <nav class="opennav-primary-links" aria-label="Primary">
      <a
        class="opennav-docs-link"
        href="/"
        aria-current={isDocsHome ? "page" : undefined}
      >
        Docs
      </a>
      <a
        class="opennav-docs-link opennav-secondary-link"
        href="/getting-started/"
        aria-current={isGettingStartedPage ? "page" : undefined}
      >
        Quick Start
      </a>
      <a
        class="opennav-docs-link opennav-secondary-link"
        href="/sdk/"
        aria-current={isSdkPage ? "page" : undefined}
      >
        SDK
      </a>
    </nav>
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<style>
  @layer starlight.core {
    .header {
      align-items: center;
      display: flex;
      gap: var(--sl-nav-gap);
      height: 100%;
      justify-content: space-between;
    }

    .title-wrapper {
      align-items: center;
      margin: -0.25rem;
      min-width: 0;
      overflow: clip;
      padding: 0.25rem;
    }

    .opennav-primary-links {
      align-items: center;
      display: flex;
      flex: 0 0 auto;
      gap: 1.5rem;
      margin-inline-start: 2.5rem;
    }

    .opennav-docs-link {
      border-block-end: 2px solid transparent;
      color: var(--opennav-docs-text-color, var(--sl-color-text));
      flex: 0 0 auto;
      font-size: var(--sl-text-sm);
      font-weight: 700;
      line-height: 1;
      padding-block: 0.35rem 0.3rem;
      text-decoration: none;
    }

    .opennav-docs-link:hover,
    .opennav-docs-link:focus-visible,
    .opennav-docs-link[aria-current="page"] {
      border-block-end-color: var(--sl-color-accent);
      color: var(--sl-color-accent);
    }

    .opennav-docs-link:focus-visible {
      outline: 2px solid var(--sl-color-accent);
      outline-offset: 0.25rem;
    }

    @media (max-width: 50rem) {
      .opennav-primary-links .opennav-secondary-link {
        display: none;
      }
    }

    .right-group,
    .social-icons {
      align-items: center;
      gap: 1rem;
    }

    .social-icons::after {
      border-inline-end: 1px solid var(--sl-color-gray-5);
      content: "";
      height: 2rem;
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }

      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }

      .header {
        --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
                var(--sl-content-width)
            ) / 2
        );
        align-content: center;
        display: grid;
        grid-template-columns:
          minmax(
            calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))),
            auto
          )
          1fr
          auto;
      }
    }
  }
</style>
