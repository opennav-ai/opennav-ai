---
import openLogo from "../assets/open-logo-padded.svg";

const siteUrl = "https://docs.opennav.ai";
const siteName = "OpenNav AI";
const pageTitle = "Page Not Found";
const pageDescription =
  "Find the OpenNav AI documentation page you were looking for.";
const socialImageUrl = `${siteUrl}/site/opennav-compass-document-layers-desktop.webp`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle} | {siteName}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#1474f0" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={pageDescription} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/404.html`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@OpenNavAI" />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={pageDescription} />
    <link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <main class="not-found" aria-labelledby="page-title">
      <a class="brand" href="/">
        <img
          src={openLogo.src}
          width={openLogo.width}
          height={openLogo.height}
          alt=""
        />
        <span>{siteName}</span>
      </a>

      <p class="eyebrow">404</p>
      <h1 id="page-title">Page not found.</h1>
      <p class="summary">
        The page may have moved, or the URL may have a typo. Start from the docs
        overview or jump back into the quick start.
      </p>
      <nav class="actions" aria-label="Not found page links">
        <a class="primary-action" href="/">Docs Home</a>
        <a class="secondary-action" href="/getting-started/">Quick Start</a>
      </nav>
    </main>
  </body>
</html>

<style>
  :root {
    --opennav-docs-text-color: #021c3f;
    --opennav-docs-muted-color: #536171;
    --opennav-docs-page-bg: #f7f6f1;
    --opennav-docs-surface-bg: rgb(255 255 255 / 0.72);
    --opennav-docs-border-color: rgb(2 28 63 / 0.12);
    --opennav-docs-blue: #1474f0;
    --opennav-docs-cyan: #31bbf5;
  }

  * {
    box-sizing: border-box;
  }

  body {
    min-height: 100vh;
    margin: 0;
    background-color: var(--opennav-docs-page-bg);
    color: var(--opennav-docs-text-color);
    font-family:
      "Space Grotesk",
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  body::before,
  body::after {
    position: fixed;
    inset: 0;
    content: "";
    pointer-events: none;
  }

  body::before {
    background-image: url("/site/opennav-compass-document-layers-desktop.webp");
    background-position: right top;
    background-repeat: no-repeat;
    background-size: max(1774px, 100vw) auto;
  }

  body::after {
    background-image:
      linear-gradient(
        90deg,
        var(--opennav-docs-page-bg) 0%,
        rgb(247 246 241 / 0.96) 29%,
        rgb(247 246 241 / 0.62) 52%,
        rgb(247 246 241 / 0.18) 72%
      ),
      linear-gradient(
        180deg,
        rgb(247 246 241 / 0.76) 0%,
        rgb(247 246 241 / 0.18) 24%,
        rgb(247 246 241 / 0.18) 72%,
        rgb(247 246 241 / 0.86) 100%
      );
  }

  .not-found {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: 100vh;
    width: min(100%, 50rem);
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 7vw, 5rem);
  }

  .brand {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.85rem;
    color: var(--opennav-docs-text-color);
    font-size: 1.125rem;
    font-weight: 700;
    text-decoration: none;
  }

  .brand img {
    width: 2.75rem;
    height: 2.75rem;
  }

  .eyebrow {
    margin: clamp(3rem, 8vw, 6rem) 0 0.75rem;
    color: var(--opennav-docs-blue);
    font-size: 1rem;
    font-weight: 700;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(3.5rem, 12vw, 7.5rem);
    line-height: 0.95;
  }

  .summary {
    max-width: 36rem;
    margin: 1.5rem 0 0;
    color: var(--opennav-docs-muted-color);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.6;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-top: 2rem;
  }

  .actions a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--opennav-docs-border-color);
    border-radius: 0.375rem;
    padding: 0.65rem 1rem;
    font-weight: 700;
    text-decoration: none;
  }

  .primary-action {
    background: var(--opennav-docs-blue);
    color: white;
  }

  .secondary-action {
    background: var(--opennav-docs-surface-bg);
    color: var(--opennav-docs-text-color);
  }

  .brand:focus-visible,
  .actions a:focus-visible {
    outline: 2px solid var(--opennav-docs-blue);
    outline-offset: 0.25rem;
  }

  @media (max-width: 40rem) {
    .not-found {
      min-height: 100svh;
      padding: 1.5rem;
    }

    .actions {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
