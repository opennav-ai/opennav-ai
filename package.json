{
  "name": "opennav-ai-workspace",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --reporter=default",
    "test:verbose": "vitest run --reporter=verbose",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "lint:fix": "npm run check && npm run format"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
